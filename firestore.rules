rules_version = '2';

// 우리집일정표(HomeSync) Firestore 보안 규칙
// 핵심: 일정(events)은 같은 그룹 구성원만 읽고 쓸 수 있으며,
//       수정/삭제는 작성자 본인만 가능하다. (전 인류 공개 방지)
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 요청자 본인의 그룹 id
    function myGroupId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId;
    }

    // 요청자가 해당 그룹의 구성원인지
    function isMemberOf(groupId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    // ---------- 사용자 프로필 ----------
    match /users/{userId} {
      // 본인 또는 같은 그룹 구성원만 조회 가능
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        resource.data.groupId == myGroupId()
      );
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ---------- 그룹 ----------
    match /groups/{groupId} {
      // 초대 코드로 그룹을 찾으려면 로그인 사용자의 조회가 필요.
      // (실제 일정 내용은 아래 events 규칙에서 구성원만 접근하도록 보호)
      allow read: if isSignedIn();

      // 생성: 본인을 owner이자 첫 구성원으로 등록할 때만 허용
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      // 수정: 결과적으로 본인이 구성원에 포함될 때만 허용(참여=본인 추가 포함)
      allow update: if isSignedIn()
        && request.auth.uid in request.resource.data.memberUids;

      allow delete: if false;

      // ---------- 일정 ----------
      match /events/{eventId} {
        // 같은 그룹 구성원만 조회
        allow read: if isMemberOf(groupId);

        // 생성: 구성원이고, 작성자(ownerUid)가 본인일 때
        allow create: if isMemberOf(groupId)
          && request.resource.data.ownerUid == request.auth.uid;

        // 수정/삭제: 작성자 본인만
        allow update, delete: if isMemberOf(groupId)
          && resource.data.ownerUid == request.auth.uid;
      }
    }
  }
}
