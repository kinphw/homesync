rules_version = '2';

// 우리집일정표(HomeSync) Firestore 보안 규칙
// 핵심: 일정(events)은 같은 그룹 구성원만 읽고 쓸 수 있으며,
//       수정/삭제는 작성자 본인만 가능하다. (전 인류 공개 방지)
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 운영자(관리자 웹 접근) 여부.
    // admins/{uid} 문서가 존재하면 운영자다. 추가/삭제는 Firebase 콘솔에서만 한다.
    // (소스·규칙에 UID를 하드코딩하지 않으므로 재배포 없이 운영자를 관리할 수 있다.)
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 요청자 본인의 그룹 id
    function myGroupId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId;
    }

    // 요청자가 해당 그룹의 구성원인지
    function isMemberOf(groupId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    // 요청자가 해당 그룹의 방장인지
    function isGroupOwner(groupId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid == request.auth.uid;
    }

    // ---------- 운영자 명단 ----------
    // admins/{uid} 문서 1개 = 운영자 1명. 문서 내용은 비어 있어도 되고
    // {note: '...', addedAt: ...} 처럼 메모를 넣어도 된다(존재 여부만 본다).
    // 추가/삭제는 Firebase 콘솔에서만(클라이언트 쓰기 전면 차단).
    match /admins/{uid} {
      // 본인이 운영자인지 확인할 수 있도록 본인 문서만 읽기 허용.
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // ---------- 사용자 프로필 ----------
    match /users/{userId} {
      // 본인 또는 같은 그룹 구성원, 또는 운영자만 조회 가능
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == userId ||
        resource.data.groupId == myGroupId()
      );
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ---------- 그룹 ----------
    match /groups/{groupId} {
      // 초대 코드로 그룹을 찾으려면 로그인 사용자의 조회가 필요.
      // (실제 일정 내용은 아래 events 규칙에서 구성원만 접근하도록 보호)
      allow read: if isSignedIn();

      // 생성: 본인을 owner이자 첫 구성원으로 등록할 때만 허용
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      // 수정: 기존 구성원(나가기·구성원 관리) 또는 새로 합류하는 본인일 때 허용
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.memberUids ||
        request.auth.uid in request.resource.data.memberUids
      );

      // 삭제: 방장만 (그룹 파괴)
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.ownerUid;

      // ---------- 일정 ----------
      match /events/{eventId} {
        // 같은 그룹 구성원, 또는 운영자(관제·일정 수 집계)만 조회
        allow read: if isMemberOf(groupId) || isAdmin();

        // 생성: 구성원이고, 작성자(ownerUid)가 본인일 때
        allow create: if isMemberOf(groupId)
          && request.resource.data.ownerUid == request.auth.uid;

        // 수정: 작성자 본인만
        allow update: if isMemberOf(groupId)
          && resource.data.ownerUid == request.auth.uid;

        // 삭제: 작성자 본인 또는 방장(그룹 삭제 시 일괄 정리)
        allow delete: if isMemberOf(groupId)
          && (resource.data.ownerUid == request.auth.uid || isGroupOwner(groupId));
      }
    }
  }
}
